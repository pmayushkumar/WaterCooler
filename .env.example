# Required API keys
RESEND_API_KEY=           # Get from https://resend.com/api-keys
GEMINI_API_KEY=           # Get from https://aistudio.google.com/apikey
SERPAPI_KEY=              # Get from https://serpapi.com/dashboard
CRON_SECRET=              # Any random string — protects the digest endpoint

# Email settings
FROM_EMAIL=hello@yourdomain.com   # Must be verified in Resend
BASE_URL=http://localhost:3000    # Used for links in emails

# Optional overrides
GEMINI_MODEL=gemini-2.0-flash              # LLM model to use
DIGEST_SCHEDULE=0 20 * * 0,2,4             # Cron expression (default: Sun/Tue/Thu 8PM)
DIGEST_TIMEZONE=America/New_York            # Timezone for cron